# Base de données locale web
MONGODB_URI=mongodb://localhost:27017/eausure
MONGODB_DB=water_quality

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret

# APIs EauSure
AUTH_API_URL=
NEXT_PUBLIC_AUTH_API_URL=
PROFILE_API_URL=
NEXT_PUBLIC_PROFILE_API_URL=
SUPPORT_API_URL=
NEXT_PUBLIC_SUPPORT_API_URL=
NEXT_PUBLIC_API_URL=

# Intégrations GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=EauSure

# Réinitialisation du mot de passe par email
MAIL_PROVIDER=resend
MAIL_FROM=EauSure <no-reply@example.com>
APP_NAME=EauSure
RESEND_API_KEY=re_your_api_key_here
BREVO_API_KEY=xkeysib-your-api-key-here

NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
NEXT_PUBLIC_MQTT_BROKER_URL=ws://broker.hivemq.com:8000/mqtt
NEXT_PUBLIC_MQTT_TOPIC=water-quality/live-data
